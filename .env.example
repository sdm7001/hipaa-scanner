# ─────────────────────────────────────────────────────────────
# HIPAA Scanner Platform — Environment Variables
# Copy to .env and fill in values before running
# ─────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hipaa:CHANGE_ME@localhost:5432/hipaa_scanner
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
SCANNER_API_SECRET=CHANGE_ME_RANDOM_64_CHARS
DEBUG=false

# ── Email (optional — for report delivery) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@texmg.com
SMTP_PASSWORD=app-password-here
FROM_EMAIL=hipaa@texmg.com

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=https://hipaa.texmg.com/api/v1

# ── Scanner CLI (set these in scanner environment) ───────────
HIPAA_API_URL=https://hipaa.texmg.com
HIPAA_API_KEY=msp-xxxxxxxxxxxx
HIPAA_CLIENT_ID=uuid-of-client
